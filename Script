-- [ 5. Big Copyable Buttons for Social Media ]
local function createBigSocialBtn(text, link, iconId, bgColor, yOffset)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size = UDim2.new(0, 280, 0, 45)
    btn.Position = UDim2.new(0.5, -140, 1, yOffset)
    btn.BackgroundColor3 = bgColor
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local icon = Instance.new("ImageLabel", btn)
    icon.Size = UDim2.new(0, 25, 0, 25)
    icon.Position = UDim2.new(0, 15, 0.5, -12.5)
    icon.BackgroundTransparency = 1
    icon.Image = iconId

    -- Copy functionality
    btn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(link)
            btn.Text = "Link copied successfully! ✔️"
            btn.BackgroundColor3 = Color3.fromRGB(46, 204, 113) -- Green success color
            task.wait(2)
            btn.Text = text
            btn.BackgroundColor3 = bgColor
        else
            btn.Text = "Executor doesn't support copying!"
            btn.BackgroundColor3 = Color3.fromRGB(231, 76, 60) -- Red error color
            task.wait(2)
            btn.Text = text
            btn.BackgroundColor3 = bgColor
        end
    end)

    -- Hover animations
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 290, 0, 50), Position = UDim2.new(0.5, -145, 1, yOffset - 2.5)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 280, 0, 45), Position = UDim2.new(0.5, -140, 1, yOffset)}):Play()
    end)
end

